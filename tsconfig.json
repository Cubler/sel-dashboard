{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "~/*": ["./app/*"]
    },
    "skipLibCheck": true
  },
  "include": ["app/**/*", "server/**/*", "tests/**/*", "vite.config.ts"]
}
